# ── Access Control ────────────────────────────────────────────────────────────

# General site access code — required for all non-admin visitors
ACCESS_CODE=your-access-code-here

# Admin access code — type this at /gate to receive admin privileges
# Gives access to /admin (invite management, finishings editor, lot status)
ADMIN_CODE=your-admin-code-here

# ── Database (Vercel KV / Upstash Redis) ──────────────────────────────────────
# Optional — if not set, state is persisted to local data/*.json files (dev only)
# On Vercel, always set these to avoid losing data on redeployment

# KV_REST_API_URL=https://xxx.upstash.io
# KV_REST_API_TOKEN=your-token-here
